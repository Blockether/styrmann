# ====================================
# Styrmann Configuration
# ====================================

# Database path (default: ./styrman.db)
STYRMAN_DATABASE_PATH=./styrman.db

# Repos base directory (default: /root/repos)
# Scanned for {org}/{repo} git repos, auto-discovered as workspaces on startup
STYRMAN_PROJECTS_PATH=/root/repos

# Styrmann URL (auto-detected if not set)
# Override for remote access or custom deployments
# STYRMAN_URL=http://localhost:4000

# ====================================
# Security
# ====================================

# API authentication token (required for production)
# If not set, authentication is DISABLED (local dev mode only)
# Generate with: openssl rand -hex 32
STYRMAN_API_TOKEN=

# Webhook signature secret for agent-completion webhook
# If not set, signature validation is DISABLED (local dev mode only)
# Generate with: openssl rand -hex 32
STYRMAN_WEBHOOK_SECRET=

# ====================================
# Discord Integration (daemon)
# ====================================

# Discord bot token (required to enable Discord integration)
# Create at https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=

# Comma-separated Discord channel IDs to monitor
# If not set, bot only responds to @mentions
# DISCORD_CHANNEL_IDS=

# Styrmann workspace ID for Discord-created tasks (default: "default")
# DISCORD_WORKSPACE_ID=default

# ====================================
# Voice (optional, requires Discord integration)
# ====================================

# OpenAI API key for Whisper speech-to-text
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ElevenLabs API key for text-to-speech
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ====================================
# Notes
# ====================================
#
# NEVER commit this file with real values!
# Copy to .env.local and configure:
#
#   cp .env.example .env.local
#
# .env.local is gitignored and will not be committed.
