{
  "name": "styrmann",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint .",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:backup": "sqlite3 mission-control.db 'PRAGMA wal_checkpoint(TRUNCATE);' && cp mission-control.db mission-control.db.backup && echo 'Backed up to mission-control.db.backup'",
    "db:restore": "cp mission-control.db.backup mission-control.db && echo 'Restored from backup'",
    "db:reset": "rm -f mission-control.db mission-control.db-* && npm run db:seed",
    "daemon": "tsx src/daemon/index.ts",
    "daemon:dev": "tsx watch src/daemon/index.ts"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.1",
    "@hello-pangea/dnd": "18.0.1",
    "@tailwindcss/postcss": "4.2.1",
    "better-sqlite3": "12.6.2",
    "clsx": "2.1.1",
    "css-tree": "3.2.1",
    "date-fns": "4.1.0",
    "discord.js": "^14.25.1",
    "lucide-react": "0.577.0",
    "marked": "17.0.4",
    "next": "16.1.6",
    "playwright": "1.58.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "13.0.0",
    "zod": "4.3.6",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/css-tree": "2.3.11",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
